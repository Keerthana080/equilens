## EquiLens AI - Environment Variables
## Copy to `.env` and fill in values. Do NOT commit `.env`.

# Gemini (Google Generative AI)
GEMINI_API_KEY=YOUR_GEMINI_API_KEY_HERE
GEMINI_MODEL=gemini-1.5-pro

# Optional (used only for nicer error messages / future expansions)
GOOGLE_CLOUD_PROJECT=YOUR_GCP_PROJECT_ID

# Backend tuning (optional)
EQUILENS_DATASET_SIZE=240
EQUILENS_SEED=26
EQUILENS_DEFAULT_THRESHOLD_A=0.62
EQUILENS_DEFAULT_THRESHOLD_B=0.62

